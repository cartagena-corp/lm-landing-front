<style>
    .footer {
        background: #0f172a; /* Deeper slate for a professional feel */
        color: #94a3b8;
        padding-top: var(--space-20);
        padding-bottom: var(--space-10);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .footer-inner {
        display: flex;
        flex-direction: column;
        gap: var(--space-16);
    }

    .footer-header {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-12);
        align-items: start;
        /* padding-bottom: var(--space-12); */
        /* border-bottom: 1px solid rgba(255, 255, 255, 0.05); */
    }

    .footer-logo {
        display: flex;
        align-items: center;
        gap: var(--space-3);
        font-size: var(--fs-xl);
        font-weight: 800;
        color: #fff;
        margin-bottom: var(--space-4);
    }

    .footer-tagline {
        font-size: var(--fs-base);
        max-width: 320px;
        line-height: 1.6;
    }

    .footer-newsletter {
        max-width: 400px;
        margin-left: auto;
    }

    .newsletter-title {
        font-size: var(--fs-lg);
        font-weight: 700;
        color: #fff;
        margin-bottom: var(--space-2);
    }

    .newsletter-desc {
        font-size: var(--fs-sm);
        margin-bottom: var(--space-4);
    }

    .newsletter-input-group {
        display: flex;
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: var(--radius-lg);
        padding: var(--space-1);
        transition: border-color 0.3s ease;
    }

    .newsletter-input-group:focus-within {
        border-color: var(--color-primary);
    }

    .newsletter-input-group input {
        flex: 1;
        background: transparent;
        border: none;
        padding: var(--space-2) var(--space-3);
        color: #fff;
        font-size: var(--fs-sm);
        outline: none;
    }

    .newsletter-input-group button {
        background: var(--color-primary);
        color: #fff;
        padding: var(--space-2) var(--space-5);
        border-radius: var(--radius-md);
        font-weight: 600;
        font-size: var(--fs-sm);
        transition: opacity 0.3s ease;
    }

    .newsletter-input-group button:hover {
        opacity: 0.9;
    }

    .footer-columns {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--space-8);
    }

    .footer-col-title {
        font-size: var(--fs-sm);
        font-weight: 700;
        color: #fff;
        margin-bottom: var(--space-6);
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .footer-col ul {
        display: flex;
        flex-direction: column;
        gap: var(--space-4);
    }

    .footer-col a {
        font-size: var(--fs-sm);
        color: #94a3b8;
        transition: color 0.3s ease;
    }

    .footer-col a:hover {
        color: #fff;
    }

    .footer-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: var(--space-10);
        margin-top: var(--space-4);
        border-top: 1px solid rgba(255, 255, 255, 0.05);
    }

    .footer-copy {
        font-size: var(--fs-xs);
        color: #64748b;
    }

    .footer-socials {
        display: flex;
        gap: var(--space-4);
    }

    .social-link {
        color: #94a3b8;
        transition: all 0.3s ease;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 38px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 50%;
    }

    .social-link:hover {
        color: #fff;
        background: var(--color-primary);
        transform: translateY(-2px);
    }

    @media (max-width: 768px) {
        .footer-header {
            grid-template-columns: 1fr;
            text-align: center;
            gap: var(--space-8);
        }
        .footer-brand-info,
        .footer-newsletter {
            margin: 0 auto;
        }
        .footer-logo {
            justify-content: center;
        }
        .footer-columns {
            grid-template-columns: repeat(2, 1fr);
        }
        .footer-footer {
            flex-direction: column-reverse;
            gap: var(--space-6);
            text-align: center;
        }
    }

    @media (max-width: 480px) {
        .footer-columns {
            grid-template-columns: 1fr;
            gap: var(--space-8);
            text-align: center;
        }
        .footer-newsletter {
            width: 100%;
        }
    }
</style>

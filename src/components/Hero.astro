---
import type { LangKey } from "../i18n/ui";
import { useTranslations } from "../i18n/utils";

interface Props {
    lang: LangKey;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero" id="hero">
    <div class="container hero-inner">
        <div class="hero-content">
            <!-- <div class="hero-badge reveal">🚀 Nueva versión 2.0 disponible</div> -->
            <h1 class="hero-headline">
                {t("hero.headline")}
                <span class="hero-accent">{t("hero.headlineAccent")}</span>
            </h1>
            <p class="hero-sub">{t("hero.sub")}</p>
            <div class="hero-actions">
                <a href={`/${lang}/#demo`} class="btn btn-primary btn-lg"
                    >{t("hero.secondary")}</a
                >
            </div>
        </div>
        <div class="hero-visual">
            <div class="hero-mockup">
                <div class="mockup-header">
                    <span class="dot red"></span>
                    <span class="dot yellow"></span>
                    <span class="dot green"></span>
                    <span class="mockup-title">LA MURALLA</span>
                </div>
                <div class="mockup-body">
                    <div class="mockup-sidebar">
                        <div class="sidebar-item active"></div>
                        <div class="sidebar-item"></div>
                        <div class="sidebar-item"></div>
                        <div class="sidebar-item"></div>
                    </div>
                    <div class="mockup-content">
                        <div class="kanban-col">
                            <div class="col-header todo"></div>
                            <div class="kanban-card"></div>
                            <div class="kanban-card"></div>
                            <div class="kanban-card sm"></div>
                        </div>
                        <div class="kanban-col">
                            <div class="col-header progress"></div>
                            <div class="kanban-card"></div>
                            <div class="kanban-card sm"></div>
                        </div>
                        <div class="kanban-col">
                            <div class="col-header done"></div>
                            <div class="kanban-card sm"></div>
                            <div class="kanban-card"></div>
                            <div class="kanban-card"></div>
                            <div class="kanban-card sm"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="hero-gradient"></div>
</section>

<style>
    .hero {
        position: relative;
        padding-top: calc(var(--nav-height) + var(--space-16));
        padding-bottom: var(--space-20);
        overflow: hidden;
    }

    .hero-inner {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-12);
        align-items: center;
    }

    .hero-badge {
        display: inline-block;
        padding: var(--space-1) var(--space-3);
        background: rgba(21, 93, 252, 0.1);
        color: var(--color-primary);
        border: 1px solid rgba(21, 93, 252, 0.2);
        border-radius: var(--radius-full);
        font-size: var(--fs-sm);
        font-weight: 600;
        margin-bottom: var(--space-5);
        animation: fadeInUp 0.8s ease both;
    }

    .hero-headline {
        font-size: var(--fs-6xl);
        font-weight: 800;
        line-height: 1.1;
        letter-spacing: -0.03em;
        color: var(--color-text);
        animation: fadeInUp 0.8s ease both;
    }

    .hero-accent {
        display: block;
        background: linear-gradient(
            135deg,
            var(--color-primary),
            var(--color-accent)
        );
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .hero-sub {
        font-size: var(--fs-xl);
        color: var(--color-text-muted);
        line-height: 1.7;
        margin-top: var(--space-6);
        max-width: 520px;
        animation: fadeInUp 0.8s ease 0.15s both;
    }

    .hero-actions {
        display: flex;
        gap: var(--space-4);
        margin-top: var(--space-8);
        animation: fadeInUp 0.8s ease 0.3s both;
    }

    /* ── Product Mockup ── */
    .hero-visual {
        display: flex;
        justify-content: center;
        animation: scaleIn 0.9s ease 0.3s both;
    }

    .hero-mockup {
        width: 100%;
        max-width: 520px;
        background: var(--color-surface);
        border-radius: var(--radius-xl);
        box-shadow: var(--shadow-xl);
        overflow: hidden;
        border: 1px solid var(--color-border);
        animation: float 6s ease-in-out infinite;
    }

    .mockup-header {
        display: flex;
        align-items: center;
        gap: var(--space-2);
        padding: var(--space-3) var(--space-4);
        background: var(--color-gray-100);
        border-bottom: 1px solid var(--color-border);
    }

    .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
    }
    .dot.red {
        background: #ef4444;
    }
    .dot.yellow {
        background: #f59e0b;
    }
    .dot.green {
        background: #10b981;
    }

    .mockup-title {
        font-size: var(--fs-xs);
        font-weight: 600;
        color: var(--color-text-muted);
        margin-left: var(--space-2);
    }

    .mockup-body {
        display: flex;
        min-height: 280px;
    }

    .mockup-sidebar {
        width: 60px;
        background: var(--color-gray-100);
        border-right: 1px solid var(--color-border);
        padding: var(--space-3);
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .sidebar-item {
        height: 8px;
        border-radius: 4px;
        background: var(--color-gray-200);
    }
    .sidebar-item.active {
        background: var(--color-primary);
    }

    .mockup-content {
        flex: 1;
        display: flex;
        gap: var(--space-3);
        padding: var(--space-3);
    }

    .kanban-col {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .col-header {
        height: 6px;
        border-radius: 3px;
        margin-bottom: var(--space-1);
    }
    .col-header.todo {
        background: var(--color-primary);
    }
    .col-header.progress {
        background: var(--color-warning);
    }
    .col-header.done {
        background: var(--color-success);
    }

    .kanban-card {
        height: 40px;
        background: var(--color-gray-100);
        border-radius: var(--radius-sm);
        border: 1px solid var(--color-border);
    }
    .kanban-card.sm {
        height: 28px;
    }

    /* Background gradient */
    .hero-gradient {
        position: absolute;
        top: -200px;
        right: -200px;
        width: 600px;
        height: 600px;
        background: radial-gradient(
            circle,
            rgba(21, 93, 252, 0.08) 0%,
            transparent 70%
        );
        z-index: -1;
        pointer-events: none;
    }

    @media (max-width: 1024px) {
        .hero-headline {
            font-size: var(--fs-5xl);
        }
    }

    @media (max-width: 768px) {
        .hero {
            padding-top: calc(var(--nav-height) + var(--space-8));
            padding-bottom: var(--space-12);
        }
        .hero-inner {
            grid-template-columns: 1fr;
            text-align: center;
        }
        .hero-headline {
            font-size: var(--fs-4xl);
        }
        .hero-sub {
            margin-left: auto;
            margin-right: auto;
        }
        .hero-actions {
            justify-content: center;
            flex-wrap: wrap;
        }
        .hero-mockup {
            max-width: 400px;
        }
    }
</style>
